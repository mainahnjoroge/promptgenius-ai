# =============================================================================
# PromptGenius AI — environment variables
# -----------------------------------------------------------------------------
# EVERY value below is OPTIONAL. With none of them set, the app runs in full
# "mock mode": the AI engine returns deterministic sample prompts, billing is
# simulated locally, and auth falls back to a dev stub. Drop real keys in to go
# live. Copy this file to `.env` (root) and/or `apps/web/.env.local`.
# =============================================================================

# --- AI (Anthropic / Claude) -------------------------------------------------
# When unset, the engine serves canned, well-structured sample output so the
# whole product is demonstrable with zero accounts.
ANTHROPIC_API_KEY=
# Default generation model + effort (see packages/core).
PROMPTGENIUS_MODEL=claude-opus-4-8
PROMPTGENIUS_EFFORT=high

# --- Auth (Clerk) ------------------------------------------------------------
# When unset, the web app uses a dev auth stub (a single local "demo" user).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Mobile (Expo) — same publishable key.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Billing (Stripe) --------------------------------------------------------
# When unset, upgrades are simulated: clicking "Upgrade" flips the user's tier
# in the database directly (no real charge).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs per paid tier (only needed for real checkout).
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# --- Database (PostgreSQL — Neon recommended) --------------------------------
# LEAVE BOTH UNSET to run with zero setup: the app uses an in-memory demo store
# (no persistence across restarts). Set them to persist real data.
#
#   DATABASE_URL — POOLED connection (host contains "-pooler"). Used by the app
#                  at runtime. Append ?sslmode=require&pgbouncer=true for Neon.
#   DIRECT_URL   — DIRECT connection (no "-pooler"). Used only by Prisma CLI for
#                  migrations / `db:push`. Append ?sslmode=require.
#
# Example (Neon):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=
DIRECT_URL=

# --- App URLs ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mobile points here for API calls (use your LAN IP on a physical device).
EXPO_PUBLIC_API_URL=http://localhost:3000
