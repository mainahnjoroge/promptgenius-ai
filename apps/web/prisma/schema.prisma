// PromptGenius AI — data model (PostgreSQL).
//
// Production uses Neon (or any Postgres). Local dev needs no database at all:
// when DATABASE_URL is unset (or not a postgres:// URL) the app runs in the
// in-memory demo mode (zero external accounts) — see persistenceEnabled in
// apps/web/src/lib/env.server.ts. To persist locally, point DATABASE_URL at a
// Neon dev branch or a local Postgres.
//
//   DATABASE_URL — pooled connection (PgBouncer), used by the app at runtime.
//   DIRECT_URL   — direct connection, used by Prisma CLI for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id // Clerk user id, or "demo-user" in mock mode
  email            String?
  tier             String   @default("starter") // starter | professional | enterprise
  billingInterval  String   @default("monthly") // monthly | annual
  usageCount       Int      @default(0)
  usagePeriodStart DateTime @default(now())
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prompts SavedPrompt[]
}

model SavedPrompt {
  id               String   @id @default(cuid())
  userId           String
  title            String
  useCase          String
  prompt           String
  exampleOutput    String
  industry         String
  skillLevel       String
  outputType       String
  platform         String
  framework        String?
  variables        String   @default("[]") // JSON-encoded CustomizationVariable[]
  optimizationTips String   @default("[]") // JSON-encoded string[]
  workflow         String? // JSON-encoded WorkflowStep[] | null
  favorite         Boolean  @default(false)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
